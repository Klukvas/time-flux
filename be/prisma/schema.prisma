generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  PAUSED
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String?      @map("password_hash")
  googleId     String?      @unique @map("google_id")
  provider     AuthProvider @default(LOCAL)
  avatarUrl    String?      @map("avatar_url")
  timezone            String   @default("UTC")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  categories    Category[]
  dayStates     DayState[]
  eventGroups   EventGroup[]
  days          Day[]
  dayMedia      DayMedia[]
  refreshTokens RefreshToken[]
  subscription  Subscription?

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String
  isSystem  Boolean  @default(false) @map("is_system")
  order     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventGroups  EventGroup[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model DayState {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String
  isSystem  Boolean  @default(false) @map("is_system")
  order     Int      @default(0)
  score     Int      @default(5) @db.SmallInt
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  days     Day[]

  @@unique([userId, name])
  @@index([userId])
  @@map("day_states")
}

model EventGroup {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  title       String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  periods  EventPeriod[]

  @@index([userId])
  @@index([userId, categoryId])
  @@index([categoryId])
  @@map("event_groups")
}

model EventPeriod {
  id           String    @id @default(uuid())
  eventGroupId String    @map("event_group_id")
  startDate    DateTime  @map("start_date") @db.Timestamptz
  endDate      DateTime? @map("end_date") @db.Timestamptz
  comment      String?   @db.VarChar(300)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  eventGroup EventGroup @relation(fields: [eventGroupId], references: [id], onDelete: Cascade)
  media      DayMedia[]

  @@index([eventGroupId])
  @@index([eventGroupId, startDate])
  @@index([eventGroupId, endDate])
  @@index([startDate])
  @@map("event_periods")
}

model Day {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  date          DateTime   @db.Date
  dayStateId    String?    @map("day_state_id")
  mainMediaId   String?    @unique @map("main_media_id")
  locationName  String?    @map("location_name") @db.VarChar(120)
  latitude      Float?     @db.DoublePrecision
  longitude     Float?     @db.DoublePrecision
  comment       String?    @db.VarChar(500)
  updatedAt     DateTime   @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayState   DayState?  @relation(fields: [dayStateId], references: [id], onDelete: SetNull)
  mainMedia  DayMedia?  @relation("MainMedia", fields: [mainMediaId], references: [id], onDelete: SetNull)
  media      DayMedia[] @relation("DayMedia")

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, dayStateId])
  @@map("days")
}

model DayMedia {
  id          String   @id @default(uuid())
  dayId       String   @map("day_id")
  userId      String   @map("user_id")
  s3Key       String   @unique @map("s3_key")
  fileName    String   @map("file_name")
  contentType String   @map("content_type")
  size        Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  periodId    String?  @map("period_id")

  day         Day          @relation("DayMedia", fields: [dayId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainForDay  Day?         @relation("MainMedia")
  period      EventPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([dayId])
  @@index([userId])
  @@index([dayId, userId])
  @@index([periodId])
  @@map("day_media")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  paddleCustomerId     String?            @unique @map("paddle_customer_id")
  paddleSubscriptionId String?            @unique @map("paddle_subscription_id")
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz
  canceledAt           DateTime?          @map("canceled_at") @db.Timestamptz
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paddleCustomerId])
  @@index([paddleSubscriptionId])
  @@map("subscriptions")
}

model WebhookEvent {
  id        String   @id
  type      String
  processed Boolean  @default(false)
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([processed, createdAt])
  @@index([type])
  @@map("webhook_events")
}
